{
  "id": "hr",
  "label": "HR Agent",
  "description": "Manages employee onboarding (create record, generate offer, collect docs, monitor checklist), leave requests and approvals, and policy document generation.",
  "model": "${LLM_MODEL_HR}",
  "system_prompt_file": "configs/prompts/hr.md",
  "sub_agents": ["document-generator"],
  "tools": [
    "data.employees.create",
    "data.employees.update",
    "data.employees.get_by_id",
    "data.hr_tasks.create_batch",
    "data.hr_tasks.update_status",
    "data.hr_tasks.get_blockers",
    "data.leave_records.create",
    "data.leave_records.update_status",
    "data.leave_balances.get_by_employee",
    "data.leave_balances.update",
    "data.policy_documents.create",
    "data.approval_requests.create",
    "notifications.send_onboarding_link",
    "notifications.send_leave_notification",
    "email.send_offer_letter"
  ],
  "confidence_thresholds": {
    "auto_execute": 0.85,
    "request_approval": 0.60,
    "recommend_only": 0.40,
    "refuse": 0.0
  },
  "max_iterations": 12,
  "timeout_seconds": 60
}
