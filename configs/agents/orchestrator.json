{
  "id": "orchestrator",
  "label": "Orchestrator Agent",
  "description": "Routes user intent to the appropriate specialist agent. Maintains conversation context. Handles multi-turn clarification before routing.",
  "model": "${LLM_MODEL_ORCHESTRATOR}",
  "system_prompt_file": "configs/prompts/orchestrator.md",
  "sub_agents": [
    "runway",
    "compliance",
    "payroll",
    "ap-invoice",
    "ar-collections",
    "hr",
    "helpdesk"
  ],
  "tools": [
    "internal.platform.healthcheck",
    "sheets.ap_invoices.get_pending_payables",
    "sheets.ar_invoices.get_pending_receivables",
    "sheets.ar_invoices.get_overdue",
    "sheets.hr_tasks.get_blockers",
    "sheets.hr_tasks.get_pending_hires",
    "sheets.compliance_calendar.get_upcoming_obligations",
    "sheets.employees.get_active_headcount",
    "sheets.employees.get_active",
    "sheets.bank_transactions.get_recent"
  ],
  "confidence_thresholds": {
    "auto_execute": 0.85,
    "request_approval": 0.60,
    "recommend_only": 0.40,
    "refuse": 0.0
  },
  "max_iterations": 5,
  "timeout_seconds": 30,
  "notes": "Orchestrator itself does not execute tools — it only routes. All execution happens in specialist agents."
}
