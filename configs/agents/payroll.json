{
  "id": "payroll",
  "label": "Payroll Agent",
  "description": "Runs monthly payroll: fetches active employees, computes gross + deductions, generates payroll run record + salary slips, creates compliance obligations, surfaces approval card.",
  "model": "claude-sonnet-4-6",
  "system_prompt_file": "configs/prompts/payroll.md",
  "sub_agents": ["document-generator"],
  "tools": [
    "sheets.employees.get_active",
    "sheets.salary_structures.get_by_id",
    "sheets.attendance.get_by_employee_month",
    "sheets.leave_records.get_by_employee_month",
    "sheets.leave_balances.get_by_employee",
    "sheets.payroll_runs.create",
    "sheets.payroll_runs.update_status",
    "sheets.salary_slips.create_batch",
    "sheets.tax_obligations.create_batch",
    "sheets.tds_records.create_batch",
    "sheets.approval_requests.create",
    "notifications.send_approval_request"
  ],
  "confidence_thresholds": {
    "auto_execute": 0.85,
    "request_approval": 0.60,
    "recommend_only": 0.40,
    "refuse": 0.0
  },
  "max_iterations": 20,
  "timeout_seconds": 120,
  "notes": "Long timeout because payroll runs process all employees sequentially."
}
