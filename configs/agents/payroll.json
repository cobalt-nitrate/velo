{
  "id": "payroll",
  "label": "Payroll Agent",
  "description": "Runs monthly payroll: fetches active employees, computes gross + deductions, generates payroll run record + salary slips, creates compliance obligations, surfaces approval card.",
  "model": "${LLM_MODEL_PAYROLL}",
  "system_prompt_file": "configs/prompts/payroll.md",
  "sub_agents": ["document-generator"],
  "tools": [
    "data.employees.get_active",
    "data.salary_structures.get_by_id",
    "data.attendance.get_by_employee_month",
    "data.leave_records.get_by_employee_month",
    "data.leave_balances.get_by_employee",
    "data.payroll_runs.create",
    "data.payroll_runs.update_status",
    "data.salary_slips.create_batch",
    "data.tax_obligations.create_batch",
    "data.tds_records.create_batch",
    "data.approval_requests.create",
    "notifications.send_approval_request"
  ],
  "confidence_thresholds": {
    "auto_execute": 0.85,
    "request_approval": 0.60,
    "recommend_only": 0.40,
    "refuse": 0.0
  },
  "max_iterations": 20,
  "timeout_seconds": 120,
  "notes": "Long timeout because payroll runs process all employees sequentially."
}
