{
  "id": "invoice-extractor",
  "label": "Invoice Extractor SubAgent",
  "description": "Extracts structured fields from raw invoice inputs: PDF, image, or pasted text. Scores confidence per field. Returns partially-filled fields if some cannot be extracted — never fabricates missing values.",
  "model": "claude-sonnet-4-6",
  "system_prompt_file": "configs/prompts/invoice-extractor.md",
  "sub_agents": [],
  "tools": [
    "ocr.extract_from_pdf",
    "ocr.extract_from_image",
    "ocr.extract_from_text"
  ],
  "output_schema": {
    "vendor_name": { "type": "string", "required": true },
    "gstin": { "type": "string", "required": false, "pattern": "^[0-9]{2}[A-Z]{5}[0-9]{4}[A-Z]{1}[1-9A-Z]{1}Z[0-9A-Z]{1}$" },
    "invoice_number": { "type": "string", "required": true },
    "invoice_date": { "type": "date", "required": true },
    "due_date": { "type": "date", "required": false },
    "line_items": {
      "type": "array",
      "items": {
        "description": { "type": "string" },
        "quantity": { "type": "number" },
        "unit_price": { "type": "number" },
        "amount": { "type": "number" },
        "gst_rate": { "type": "number" },
        "gst_amount": { "type": "number" }
      }
    },
    "subtotal": { "type": "number", "required": true },
    "total_gst": { "type": "number", "required": true },
    "total_amount": { "type": "number", "required": true },
    "currency": { "type": "string", "default": "INR" }
  },
  "confidence_per_field": true,
  "max_iterations": 5,
  "timeout_seconds": 30
}
