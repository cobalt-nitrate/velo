  invoiceDate   String @default("") @map("invoice_date")
  periodMonth   String @default("") @map("period_month")
  periodYear    String @default("") @map("period_year")
  invoiceAmount String @default("") @map("invoice_amount")
  gstAmount     String @default("") @map("gst_amount")
  gstRate       String @default("") @map("gst_rate")
  itcClaimable  String @default("") @map("itc_claimable")
  itcClaimed    String @default("") @map("itc_claimed")
  itcAmount     String @default("") @map("itc_amount")
  category      String @default("")
