  contactPhone     String @default("") @map("contact_phone")
  paymentTermsDays String @default("") @map("payment_terms_days")
  createdAt        String @default("") @map("created_at")
  updatedAt        String @default("") @map("updated_at")

  @@map("client_master")
}

model BankPayee {
  id         String @id @default(cuid())
  payeeId    String @unique @map("payee_id")
  vendorId   String @default("") @map("vendor_id")
  vendorName String @default("") @map("vendor_name")
  bankAccount String @default("") @map("bank_account")
  ifsc       String @default("")
  bankName   String @default("") @map("bank_name")
  addedDate  String @default("") @map("added_date")
  status     String @default("")
