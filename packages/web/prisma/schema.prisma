}

model ArInvoice {
  id                  String @id @default(cuid())
  invoiceId           String @unique @map("invoice_id")
  clientId            String @default("") @map("client_id")
  clientName          String @default("") @map("client_name")
  invoiceNumber       String @default("") @map("invoice_number")
  invoiceDate         String @default("") @map("invoice_date")
  dueDate             String @default("") @map("due_date")
  serviceDescription  String @default("") @map("service_description")
  subtotal            String @default("")
  igst                String @default("")
  cgst                String @default("")
  sgst                String @default("")
  totalAmount         String @default("") @map("total_amount")
