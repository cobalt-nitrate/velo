model Document {
  id            String   @id @default(cuid())
  documentId    String   @unique @map("document_id")
  type          String   @default("")
  title         String   @default("")

  subjectType   String   @default("") @map("subject_type")
  subjectId     String   @default("") @map("subject_id")
  employeeEmail String   @default("") @map("employee_email")

  periodMonth   String   @default("") @map("period_month")
  periodYear    String   @default("") @map("period_year")
  tagsJson      String   @default("") @map("tags_json") @db.Text

  createdAt     DateTime @default(now()) @map("created_at")
  createdBy     String   @default("") @map("created_by")
  source        String   @default("")

  latestVersionId String @default("") @map("latest_version_id")

  versions      DocumentVersion[]
  tokens        DocumentAccessToken[]

  @@index([type])
  @@index([employeeEmail])
  @@index([subjectType, subjectId])
  @@index([createdAt(sort: Desc)])
  @@map("documents")
}

model DocumentVersion {
  id          String   @id @default(cuid())
  versionId   String   @unique @map("version_id")
  documentId  String   @map("document_id")

  format      String   @default("") // pdf | html
  mime        String   @default("")
  sha256      String   @default("")
  sizeBytes   Int      @default(0) @map("size_bytes")

  storage     String   @default("") // drive | inline | local
  driveFileId String   @default("") @map("drive_file_id")
  driveWebViewUrl String @default("") @map("drive_web_view_url")
  localUploadId String  @default("") @map("local_upload_id")
  inlineDataUrl String  @default("") @map("inline_data_url") @db.Text

  renderParamsJson String @default("") @map("render_params_json") @db.Text

  createdAt   DateTime @default(now()) @map("created_at")

  document Document @relation(fields: [documentId], references: [documentId], onDelete: Cascade)
  tokens   DocumentAccessToken[]

  @@index([documentId])
  @@index([createdAt(sort: Desc)])
  @@map("document_versions")
}

model DocumentAccessToken {
  id        String   @id @default(cuid())
  tokenId   String   @unique @map("token_id")

  documentId String  @default("") @map("document_id")
  versionId  String  @default("") @map("version_id")

  scope     String   @default("") // preview | download
  recipientEmail String @default("") @map("recipient_email")

  expiresAt DateTime @map("expires_at")
  revokedAt DateTime? @map("revoked_at")

  createdAt DateTime @default(now()) @map("created_at")
  createdBy String   @default("") @map("created_by")

  document Document? @relation(fields: [documentId], references: [documentId], onDelete: Cascade)
  version  DocumentVersion? @relation(fields: [versionId], references: [versionId], onDelete: Cascade)

  @@index([documentId])
  @@index([versionId])
  @@index([expiresAt])
  @@map("document_access_tokens")
}
