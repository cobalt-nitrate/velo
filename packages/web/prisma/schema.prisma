  vendorName      String @default("") @map("vendor_name")
  invoiceNumber   String @default("") @map("invoice_number")
  invoiceDate     String @default("") @map("invoice_date")
  dueDate         String @default("") @map("due_date")
  lineItemsJson   String @default("") @map("line_items_json") @db.Text
  subtotal        String @default("")
  gstAmount       String @default("") @map("gst_amount")
  totalAmount     String @default("") @map("total_amount")
  expenseCategory String @default("") @map("expense_category")
  subCategory     String @default("") @map("sub_category")
  itcClaimable    String @default("") @map("itc_claimable")
  itcAmount       String @default("") @map("itc_amount")
  paymentStatus   String @default("") @map("payment_status")
  paymentDate     String @default("") @map("payment_date")
  bankReference   String @default("") @map("bank_reference")
  approver        String @default("")
  approvedAt      String @default("") @map("approved_at")
  sourceFileUrl   String @default("") @map("source_file_url")
  notes           String @default("")
  createdAt       String @default("") @map("created_at")

  @@index([paymentStatus])
