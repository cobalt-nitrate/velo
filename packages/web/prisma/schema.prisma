  esicEmployerTotal String @default("") @map("esic_employer_total")
  status            String @default("")
  approvedBy        String @default("") @map("approved_by")
  approvedAt        String @default("") @map("approved_at")
  createdAt         String @default("") @map("created_at")

  @@map("payroll_runs")
}

model SalarySlip {
  id               String @id @default(cuid())
  slipId           String @unique @map("slip_id")
  runId            String @default("") @map("run_id")
  employeeId       String @default("") @map("employee_id")
  employeeName     String @default("") @map("employee_name")
  month            String @default("")
  year             String @default("")
  basic            String @default("")
  hra              String @default("")
  lta              String @default("")
  specialAllowance String @default("") @map("special_allowance")
  grossSalary      String @default("") @map("gross_salary")
  pfEmployee       String @default("") @map("pf_employee")
  esicEmployee     String @default("") @map("esic_employee")
  pt               String @default("")
  tds              String @default("")
  lopDeduction     String @default("") @map("lop_deduction")
  totalDeductions  String @default("") @map("total_deductions")
  netSalary        String @default("") @map("net_salary")
  workingDays      String @default("") @map("working_days")
  lopDays          String @default("") @map("lop_days")
  driveUrl         String @default("") @map("drive_url")
  createdAt        String @default("") @map("created_at")

  @@index([employeeId])
  @@map("salary_slips")
}

model LeaveRecord {
  id           String @id @default(cuid())
  recordId     String @unique @map("record_id")
  employeeId   String @default("") @map("employee_id")
  employeeName String @default("") @map("employee_name")
  leaveType    String @default("") @map("leave_type")
  fromDate     String @default("") @map("from_date")
  toDate       String @default("") @map("to_date")
  days         String @default("")
  reason       String @default("")
  status       String @default("")
  approver     String @default("")
  approvedAt   String @default("") @map("approved_at")
  createdAt    String @default("") @map("created_at")

  @@map("leave_records")
}

model LeaveBalance {
  id             String @id @default(cuid())
  balanceId      String @unique @map("balance_id")
  employeeId     String @default("") @map("employee_id")
  leaveType      String @default("") @map("leave_type")
  year           String @default("")
  openingBalance String @default("") @map("opening_balance")
  accrued        String @default("")
  used           String @default("")
  closingBalance String @default("") @map("closing_balance")
  lastUpdated    String @default("") @map("last_updated")

