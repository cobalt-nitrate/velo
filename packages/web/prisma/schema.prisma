}

model LeaveType {
  id                    String @id @default(cuid())
  leaveTypeId           String @unique @map("leave_type_id")
  label                 String @default("")
  annualEntitlementDays String @default("") @map("annual_entitlement_days")
  carryForwardMax       String @default("") @map("carry_forward_max")
  encashable            String @default("")
  paid                  String @default("")
  accrual               String @default("")
  notes                 String @default("")

  @@map("leave_types")
}

model ComplianceRule {
  id               String @id @default(cuid())
  ruleId           String @unique @map("rule_id")
  label            String @default("")
  frequency        String @default("")
  dueDayOfMonth    String @default("") @map("due_day_of_month")
  applicableMonths String @default("") @map("applicable_months")
  applicableStates String @default("") @map("applicable_states")
  portal           String @default("")
  penaltyNotes     String @default("") @map("penalty_notes")

  @@map("compliance_rules")
}

// ─── MASTER ───────────────────────────────────────────────────────────────────

model Employee {
  id                String @id @default(cuid())
  employeeId        String @unique @map("employee_id")
  fullName          String @default("") @map("full_name")
  email             String @default("")
  personalEmail     String @default("") @map("personal_email")
  phone             String @default("")
  dob               String @default("")
  gender            String @default("")
  pan               String @default("")
  aadhaar           String @default("")
  address           String @default("")
  designation       String @default("")
  department        String @default("")
  reportsTo         String @default("") @map("reports_to")
  doj               String @default("")
  doe               String @default("")
  status            String @default("active")
  employmentType    String @default("") @map("employment_type")
  salaryStructureId String @default("") @map("salary_structure_id")
  ctcAnnualInr      String @default("") @map("ctc_annual_inr")
  pfUan             String @default("") @map("pf_uan")
  esicIpNumber      String @default("") @map("esic_ip_number")
  ptApplicable      String @default("") @map("pt_applicable")
  tdsRegime         String @default("") @map("tds_regime")
  bankAccountNumber String @default("") @map("bank_account_number")
  bankIfsc          String @default("") @map("bank_ifsc")
  bankName          String @default("") @map("bank_name")
  createdAt         String @default("") @map("created_at")
  updatedAt         String @default("") @map("updated_at")

  @@index([status])
  @@map("employees")
}

model SalaryStructure {
  id                       String @id @default(cuid())
  structureId              String @unique @map("structure_id")
  label                    String @default("")
  description              String @default("")
  basicPctOfCtc            String @default("") @map("basic_pct_of_ctc")
  hraPctOfBasic            String @default("") @map("hra_pct_of_basic")
  ltaPctOfCtc              String @default("") @map("lta_pct_of_ctc")
  specialAllowanceResidual String @default("") @map("special_allowance_residual")
  effectiveFrom            String @default("") @map("effective_from")
  createdAt                String @default("") @map("created_at")

  @@map("salary_structures")
}

model Vendor {
