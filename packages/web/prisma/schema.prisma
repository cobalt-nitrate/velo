}

model Attendance {
  id                 String @id @default(cuid())
  recordId           String @unique @map("record_id")
  employeeId         String @default("") @map("employee_id")
  month              String @default("")
  year               String @default("")
  workingDaysInMonth String @default("") @map("working_days_in_month")
  daysPresent        String @default("") @map("days_present")
  daysAbsent         String @default("") @map("days_absent")
  lopDays            String @default("") @map("lop_days")
  wfhDays            String @default("") @map("wfh_days")
  updatedAt          String @default("") @map("updated_at")

  @@map("attendance")
}

model ApprovalRequest {
  id                      String @id @default(cuid())
  approvalId              String @unique @map("approval_id")
  agentId                 String @default("") @map("agent_id")
  actionType              String @default("") @map("action_type")
  actionPayloadJson       String @default("{}") @map("action_payload_json") @db.Text
  confidenceScore         String @default("") @map("confidence_score")
  evidenceJson            String @default("[]") @map("evidence_json") @db.Text
  proposedActionText      String @default("") @map("proposed_action_text")
  createdAt               String @default("") @map("created_at")
  expiresAt               String @default("") @map("expires_at")
  status                  String @default("PENDING")
  approverRole            String @default("") @map("approver_role")
  resolvedBy              String @default("") @map("resolved_by")
  resolvedAt              String @default("") @map("resolved_at")
  resolutionNotes         String @default("") @map("resolution_notes")
  attachmentDriveUrlsJson String @default("") @map("attachment_drive_urls_json") @db.Text
  resubmittedFromApprovalId String @default("") @map("resubmitted_from_approval_id")
  supersededByApprovalId    String @default("") @map("superseded_by_approval_id")

  events      ApprovalEvent[]
  evidence    ApprovalEvidenceItem[]
  signalScores ApprovalSignalScore[]

  @@index([status])
  @@map("approval_requests")
}

model ApprovalEvent {
  id         String   @id @default(cuid())
  approvalId String   @map("approval_id")
  type       String
  actorId    String   @default("") @map("actor_id")
  actorRole  String   @default("") @map("actor_role")
  notes      String   @default("") @db.Text
  payload    Json     @default("{}")
  createdAt  DateTime @default(now()) @map("created_at")

  approval ApprovalRequest @relation(fields: [approvalId], references: [approvalId], onDelete: Cascade)

  @@index([approvalId])
  @@index([createdAt(sort: Desc)])
  @@map("approval_events")
}

model ApprovalEvidenceItem {
  id         String @id @default(cuid())
  approvalId String @map("approval_id")
  kind       String @default("")
  label      String @default("")
  value      String @default("") @db.Text
  source     String @default("")
  meta       Json   @default("{}")

  approval ApprovalRequest @relation(fields: [approvalId], references: [approvalId], onDelete: Cascade)

  @@index([approvalId])
  @@index([kind])
  @@map("approval_evidence_items")
}

model ApprovalSignalScore {
  id         String @id @default(cuid())
  approvalId String @map("approval_id")
  signal     String @default("")
  score      Float  @default(0)
  detail     String @default("") @db.Text

  approval ApprovalRequest @relation(fields: [approvalId], references: [approvalId], onDelete: Cascade)

  @@index([approvalId])
  @@index([signal])
  @@map("approval_signal_scores")
}

model HrTask {
  id                 String @id @default(cuid())
