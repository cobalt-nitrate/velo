  @@map("bank_payees")
}

// ─── TRANSACTIONS ─────────────────────────────────────────────────────────────

model BankTransaction {
  id        String @id @default(cuid())
  txnId     String @unique @map("txn_id")
  companyId String @default("") @map("company_id")
