model ComplianceCalendar {
  id              String @id @default(cuid())
  calendarId      String @unique @map("calendar_id")
  type            String @default("")
  label           String @default("")
  periodMonth     String @default("") @map("period_month")
  periodYear      String @default("") @map("period_year")
  dueDate         String @default("") @map("due_date")
  status          String @default("")
