  narration String @default("")
  refNumber String @default("") @map("ref_number")
  amount    String @default("")
  balance   String @default("")
  type      String @default("")
  mode      String @default("")
  source    String @default("")
  createdAt String @default("") @map("created_at")

  @@index([date])
  @@index([companyId])
  @@map("bank_transactions")
}

model ApInvoice {
