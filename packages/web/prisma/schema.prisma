  ledgerId      String @unique @map("ledger_id")
  arInvoiceId   String @default("") @map("ar_invoice_id")
  clientName    String @default("") @map("client_name")
  invoiceDate   String @default("") @map("invoice_date")
  periodMonth   String @default("") @map("period_month")
  periodYear    String @default("") @map("period_year")
  taxableAmount String @default("") @map("taxable_amount")
  igst          String @default("")
  cgst          String @default("")
  sgst          String @default("")
  totalGst      String @default("") @map("total_gst")
  createdAt     String @default("") @map("created_at")

  @@map("gst_output_ledger")
