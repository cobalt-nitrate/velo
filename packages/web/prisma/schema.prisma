  bankName         String @default("") @map("bank_name")
  paymentTermsDays String @default("") @map("payment_terms_days")
  isPayeeAdded     String @default("") @map("is_payee_added")
  contactEmail     String @default("") @map("contact_email")
  contactPhone     String @default("") @map("contact_phone")
  createdAt        String @default("") @map("created_at")
  updatedAt        String @default("") @map("updated_at")

  @@map("vendor_master")
}

model Client {
  id               String @id @default(cuid())
  clientId         String @unique @map("client_id")
  clientName       String @default("") @map("client_name")
  gstin            String @default("")
  pan              String @default("")
  billingAddress   String @default("") @map("billing_address")
  state            String @default("")
