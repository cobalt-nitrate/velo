{
  "name": "@velo/web",
  "version": "0.1.0",
  "private": true,
  "description": "Next.js Command Center — chat UI, approval cards, dashboards",
  "scripts": {
    "dev": "node -r ./lib/register-env.cjs ./node_modules/next/dist/bin/next dev",
    "dev:clean": "rm -rf .next && node -r ./lib/register-env.cjs ./node_modules/next/dist/bin/next dev",
    "build": "next build",
    "build:clean": "rm -rf .next && next build",
    "start": "node -r ./lib/register-env.cjs ./node_modules/next/dist/bin/next start",
    "lint": "next lint",
    "db:generate": "dotenv -e .env.local -e .env -- prisma generate",
    "db:migrate": "dotenv -e .env.local -e .env -- prisma migrate dev",
    "db:migrate:deploy": "dotenv -e .env.local -e .env -- prisma migrate deploy",
    "db:push": "dotenv -e .env.local -e .env -- prisma db push",
    "db:studio": "dotenv -e .env.local -e .env -- prisma studio",
    "db:reset": "dotenv -e .env.local -e .env -- prisma migrate reset",
    "db:seed": "pnpm exec dotenv -e ../../.env.local -e .env.local -- npx tsx ../../scripts/seed-postgres-demo.ts"
  },
  "prisma": {
    "seed": "pnpm exec dotenv -e ../../.env.local -e .env.local -- npx tsx ../../scripts/seed-postgres-demo.ts"
  },
  "dependencies": {
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^5.22.0",
    "@velo/agents": "workspace:*",
    "@velo/core": "workspace:*",
    "@velo/tools": "workspace:*",
    "bcryptjs": "^3.0.3",
    "googleapis": "^140.0.0",
    "jose": "^4.15.9",
    "next": "^14.2.0",
    "next-auth": "^4.24.0",
    "openai": "^4.77.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "autoprefixer": "^10.4.0",
    "dotenv-cli": "^11.0.0",
    "postcss": "^8.4.0",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0"
  }
}
