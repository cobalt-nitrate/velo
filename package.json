{
  "name": "velo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "workspaces": [
    "packages/*"
  ],
  "description": "Autonomous Back-Office OS for Startups",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "npx --yes pnpm@9.15.0 --filter @velo/web dev",
    "build": "npx --yes pnpm@9.15.0 -r run build",
    "build:turbo": "turbo run build",
    "test": "npx --yes pnpm@9.15.0 -r run test",
    "lint": "npx --yes pnpm@9.15.0 -r run lint",
    "setup-sheets": "node scripts/setup-sheets-run.js",
    "ensure-bank-tab": "node scripts/ensure-bank-transactions-tab.js",
    "audit-sheet-locations": "node scripts/audit-velo-sheet-locations.js",
    "ensure-file-links": "node scripts/ensure-file-links-tab.js",
    "seed-mock-data": "node scripts/seed-mock-velo-data.js",
    "seed-mock:generate": "node scripts/gen-velo-demo-seed.js",
    "validate-configs": "pnpm --filter @velo/core validate-configs",
    "verify:ci": "pnpm validate-configs && pnpm exec tsc --noEmit -p packages/core && pnpm exec tsc --noEmit -p packages/agents && pnpm exec tsc --noEmit -p packages/tools && pnpm exec tsc --noEmit -p packages/web",
    "e2e:modules": "pnpm --filter @velo/agents e2e:modules",
    "seed-compliance": "node scripts/seed-compliance-calendar.js"
  },
  "devDependencies": {
    "googleapis": "^171.4.0",
    "tsx": "^4.0.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
