# ─── LLM (NVIDIA NIM — OpenAI-compatible API) ───────────────────────────────
# Agent runtime (@velo/agents) uses the official OpenAI client with LLM_BASE_URL.
LLM_API_KEY=
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
# When an agent JSON uses ${LLM_MODEL_AP_INVOICE} etc. but that env is empty, this is used.
LLM_MODEL_DEFAULT=

# Model IDs — one per agent, fill from NVIDIA model catalog
# Orchestrator (most capable — routes all user intent)
LLM_MODEL_ORCHESTRATOR=

# Specialist agents (mid-tier — own reasoning + tool use)
LLM_MODEL_RUNWAY=
LLM_MODEL_COMPLIANCE=
LLM_MODEL_PAYROLL=
LLM_MODEL_AP_INVOICE=
LLM_MODEL_AR_COLLECTIONS=
LLM_MODEL_HR=

# Sub-agents (fast + cheap — single-purpose extraction/classification)
LLM_MODEL_INVOICE_EXTRACTOR=
LLM_MODEL_EXPENSE_CLASSIFIER=
LLM_MODEL_VENDOR_MATCHER=
LLM_MODEL_DUPLICATE_DETECTOR=
LLM_MODEL_DOCUMENT_GENERATOR=

# Employee-facing agents (lightweight — high frequency)
LLM_MODEL_HELPDESK=
LLM_MODEL_TAX_PLANNING=

# ─── Google (Sheets + Drive) ──────────────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_EMAIL=velo-sa@velo-backops.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_PROJECT_ID=velo-backops

# Spreadsheet IDs
SHEETS_CONFIG_ID=1mdiQ83GU0YnzklB60HQsjcLAomJh2ttPM01u3o-yoOM
SHEETS_MASTER_ID=1r5Paz9PfIrldmTVsmhVLn1VA_1M7BOsvlQY3rqi2E4o
SHEETS_TRANSACTIONS_ID=1pFOlH01tf6zfm8IIpwzaAZOVJP6T_cmrlPdydSu6Y0M
SHEETS_COMPLIANCE_ID=1O2juVh0fdNqcSBxKOWDYid9oA0GYQaYlsbTKi9zublI
SHEETS_LOGS_ID=1gFv7rqhu0nx9rLFOF6ZlNAUl27owfYaxl34GKU-y9ik

# Alternative to many of the keys below: Command Center → Settings → Connectors
# saves an overlay file at .velo/connector-env.json (gitignored). Host env still wins on boot
# when both are set. The @velo/web dev/start scripts preload that file via
# packages/web/lib/register-env.cjs so API routes see credentials; if you run `next` directly,
# use: node -r ./lib/register-env.cjs ./node_modules/next/dist/bin/next dev
# If Next dev shows "Cannot find module './NNNN.js'" or 500s on static chunks, delete
# packages/web/.next and run: pnpm dev:web:clean (from repo root)

# ─── App ─────────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=generate_a_random_string_here
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (for user login — create at console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID= 
GOOGLE_CLIENT_SECRET=

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Get your key at resend.com. Required for AR invoice emails and approval notifications.
RESEND_API_KEY=
# From address for outbound emails (must be a verified domain in Resend)
VELO_EMAIL_FROM=Velo <noreply@mail.yourdomain.com>

# ─── Notifications (Slack) ───────────────────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
# Optional override; default #approvals (see packages/tools notifications)
# SLACK_CHANNEL_APPROVALS=#approvals

# ─── Scheduled jobs (Wave 2) ───────────────────────────────────────────────────
# Protect POST /api/cron/digest and POST /api/cron/escalate-approvals
VELO_CRON_SECRET=
# Default company_id passed into notification payloads
# VELO_COMPANY_ID=demo-company
# Email copy of scheduled digest (Resend)
# VELO_DIGEST_EMAIL_TO=founder@yourdomain.com
# Email when a new approval is created (in addition to Slack)
# VELO_APPROVAL_EMAIL_TO=founder@yourdomain.com

# ─── Workflow / state ─────────────────────────────────────────────────────────
# Optional override for .velo/workflow-runs.json directory
# VELO_STATE_DIR=

# ─── Access control ───────────────────────────────────────────────────────────
# Restrict sign-in to one Google Workspace domain (leave blank to allow any Google account)
VELO_ALLOWED_DOMAIN=yourdomain.com
# Comma-separated email lists for role assignment
VELO_FOUNDER_EMAILS=founder@yourdomain.com
VELO_FINANCE_EMAILS=finance@yourdomain.com,ca@yourdomain.com
VELO_HR_EMAILS=hr@yourdomain.com
