# Copy this to .env.local and fill in your values
# NEVER commit .env.local to git

# Anthropic (Claude) API Key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Service Account (runtime credentials for Velo app to read/write Sheets)
# Values come from velo-sa-key.json — do not commit that file either
GOOGLE_SERVICE_ACCOUNT_EMAIL=velo-sa@velo-backops.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_PROJECT_ID=velo-backops

# Google Spreadsheet IDs (auto-populated by scripts/setup-sheets-run.js)
SHEETS_CONFIG_ID=1mdiQ83GU0YnzklB60HQsjcLAomJh2ttPM01u3o-yoOM
SHEETS_MASTER_ID=1r5Paz9PfIrldmTVsmhVLn1VA_1M7BOsvlQY3rqi2E4o
SHEETS_TRANSACTIONS_ID=1pFOlH01tf6zfm8IIpwzaAZOVJP6T_cmrlPdydSu6Y0M
SHEETS_COMPLIANCE_ID=1O2juVh0fdNqcSBxKOWDYid9oA0GYQaYlsbTKi9zublI
SHEETS_LOGS_ID=1gFv7rqhu0nx9rLFOF6ZlNAUl27owfYaxl34GKU-y9ik

# App
NEXTAUTH_SECRET=generate_a_random_string_here
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (for user login via NextAuth — create at console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
